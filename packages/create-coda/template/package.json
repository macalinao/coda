{
  "name": "my-coda-client",
  "version": "0.1.0",
  "description": "TypeScript client for Solana program",
  "type": "module",
  "sideEffects": false,
  "license": "Apache-2.0",
  "keywords": [
    "coda",
    "solana",
    "client",
    "typescript"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -fr dist/ tsconfig.tsbuildinfo",
    "codegen": "rm -fr src/generated/ && coda generate",
    "lint": "oxlint"
  },
  "peerDependencies": {
    "@solana/kit": "*",
    "@solana/program-client-core": "*"
  },
  "devDependencies": {
    "@macalinao/coda": "^0.4.10",
    "@macalinao/tsconfig": "^3.2.5",
    "@solana/kit": "*",
    "@solana/program-client-core": "*",
    "@types/bun": "catalog:",
    "oxlint": "1.69.0",
    "oxlint-tsgolint": "0.23.0",
    "typescript": "^6.0.3"
  }
}
