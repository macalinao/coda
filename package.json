{
  "name": "@macalinao/coda-monorepo",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "author": "Ian Macalinao <me@ianm.com>",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "clients/*"
    ],
    "catalog": {
      "eslint": "^10.4.1",
      "typescript": "^6.0.3",
      "@macalinao/eslint-config": "^8.1.0",
      "@macalinao/tsconfig": "^3.2.5",
      "typescript-eslint": "^8.60.1",
      "@solana/kit": "^6.9.0",
      "@solana/program-client-core": "^6.9.0",
      "@types/bun": "^1.3.14",
      "codama": "^1.7.0",
      "@codama/nodes": "^1.7.0",
      "@codama/nodes-from-anchor": "^1.5.0",
      "@codama/renderers-core": "^1.3.8",
      "@codama/visitors-core": "^1.7.0",
      "ws": "^8.21.0"
    }
  },
  "scripts": {
    "build": "turbo build",
    "build:ci": "turbo build --filter='./{packages,clients}/**'",
    "build:packages": "turbo build --filter='./packages/**'",
    "build:watch": "turbo watch build",
    "build:watch:packages": "turbo watch build --filter='./packages/**'",
    "lint": "biome check && turbo run lint",
    "lint:fix": "biome check --write --no-errors-on-unmatched --unsafe && turbo run lint -- --fix && biome check --write --no-errors-on-unmatched --unsafe",
    "clean": "turbo run clean && rm -rf node_modules/ docs/",
    "test": "CI=true turbo run test",
    "watch": "turbo watch build",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "ci:version": "changeset version && bun update",
    "ci:publish": "./scripts/ci-publish.sh",
    "prepare": "husky",
    "codegen": "turbo run codegen",
    "docs:dev": "turbo dev --filter=coda-docs",
    "docs:build": "turbo build --filter=coda-docs",
    "format": "prettier --write \"**/*.{md,mdx}\""
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@changesets/cli": "^2.31.0",
    "@macalinao/biome-config": "^0.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "wrangler": "^4.98.0"
  },
  "packageManager": "bun@1.3.13",
  "lint-staged": {
    "*.{json,jsonc,html}": "biome format --write --no-errors-on-unmatched",
    "*.{md,mdx}": "prettier --write"
  },
  "overrides": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
